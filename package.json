{
  "name": "@neelegirly/wa-api",
  "version": "1.7.15",
  "description": "Neelegirly multi-session wrapper API for @neelify/baileys (WhatsApp Web)",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neelegirly/wa-api.git"
  },
  "homepage": "https://github.com/neelegirly/wa-api#readme",
  "bugs": {
    "url": "https://github.com/neelegirly/wa-api/issues"
  },
  "files": [
    "dist/**/*",
    "readme.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "tsc && node ./dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "run-script": "node ./dist/index.js"
  },
  "author": {
    "name": "Neelegirly"
  },
  "license": "ISC",
  "dependencies": {
    "jest": "^29.0.0",
    "@adiwajshing/keyed-db": "^0.2.4",
    "@hapi/boom": "^10.0.1",
    "@neelify/baileys": "2.2.16",
    "mime": "^3.0.0",
    "pino": "^8.11.0",
    "qrcode-terminal": "^0.12.0"
  },
  "overrides": {
    "@neelify/baileys": "2.2.16"
  },
  "devDependencies": {
    "@types/mime": "^3.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "neelegirly",
    "whatsapp",
    "baileys",
    "multi-session",
    "wa-api",
    "qr-branding"
  ]
}
